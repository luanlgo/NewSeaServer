{
  "name": "sea-of-code",
  "version": "1.0.0",
  "description": "Multiplayer 3D naval battle game",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "kill": "npx kill-port 3000 3001",
    "dev:clean": "npm run kill && npm run dev",
    "clean": "rm -rf dist",
    "start": "npm run build && cross-env NODE_ENV=production node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "three": "^0.183.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "clean-css-cli": "^5.6.3",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.31.1",
    "nodemon": "^3.0.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
